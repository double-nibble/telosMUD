# Template for the gitignored deploy/auth.local.env (Phase 14.7 GitHub OAuth).
# Copy to deploy/auth.local.env and fill in your GitHub OAuth app's credentials:
#
#   cp deploy/auth.env.example deploy/auth.local.env   # then edit the copy
#
# GitHub -> Settings -> Developer settings -> OAuth Apps -> New OAuth App
#   Homepage URL:           http://localhost:8080
#   Authorization callback:  http://localhost:8080/auth/github/callback
#
# The CLIENT_SECRET is sensitive; auth.local.env is gitignored so it never lands in git.

TELOS_GITHUB_CLIENT_ID=
TELOS_GITHUB_CLIENT_SECRET=
